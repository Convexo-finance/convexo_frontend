# ─── Network ──────────────────────────────────────────────────────────────────
# 'mainnet' → Base (8453) as primary chain
# 'testnet' → ETH Sepolia (11155111) as primary chain (ZKPassport verifier + pool live)
NEXT_PUBLIC_NETWORK_MODE=testnet

# ─── Backend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Privy Auth ───────────────────────────────────────────────────────────────
# Embedded wallet — get from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id
NEXT_PUBLIC_PRIVY_CLIENT_ID=your_privy_client_id

# ─── Alchemy ──────────────────────────────────────────────────────────────────
# Transaction layer (smart wallet client + RPC reads)
# Get from https://dashboard.alchemy.com
NEXT_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key

# Gas Manager policy IDs — from Alchemy Dashboard → Gas Manager → Policies
# Each policy must allowlist the correct origin (e.g. protocol.convexo.xyz)
NEXT_PUBLIC_ALCHEMY_POLICY_ID=your_base_mainnet_policy_id
NEXT_PUBLIC_ALCHEMY_POLICY_ID_SEPOLIA=your_eth_sepolia_policy_id
NEXT_PUBLIC_ALCHEMY_POLICY_ID_ETH=your_eth_mainnet_policy_id

# ─── ZKPassport ───────────────────────────────────────────────────────────────
# Must match APP_DOMAIN constant in Convexo_Passport.sol (protocol.convexo.xyz)
# Do NOT change without redeploying the passport contract
NEXT_PUBLIC_ZKPASSPORT_DOMAIN=protocol.convexo.xyz

# ─── Pinata IPFS ──────────────────────────────────────────────────────────────
# Get from https://app.pinata.cloud → API Keys
PINATA_JWT=your_pinata_jwt_token_here
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
NEXT_PUBLIC_PINATA_GATEWAY=lime-famous-condor-7.mypinata.cloud

# ─── Etherscan ────────────────────────────────────────────────────────────────
ETHERSCAN_API_KEY=your_etherscan_api_key

# ─── RPC URLs ─────────────────────────────────────────────────────────────────
# Testnet
ETHEREUM_SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/your_infura_key
BASE_SEPOLIA_RPC_URL=https://base-sepolia.infura.io/v3/your_infura_key
UNICHAIN_SEPOLIA_RPC_URL=https://sepolia.unichain.org

# Mainnet
ETHEREUM_MAINNET_RPC_URL=https://mainnet.infura.io/v3/your_infura_key
BASE_MAINNET_RPC_URL=https://base-mainnet.infura.io/v3/your_infura_key
UNICHAIN_MAINNET_RPC_URL=https://mainnet.unichain.org
